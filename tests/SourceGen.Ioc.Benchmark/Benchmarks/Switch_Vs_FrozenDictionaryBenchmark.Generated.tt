<#@ template debug="false" hostspecific="false" language="C#" #>
<#@ assembly name="System.Core" #>
<#@ output extension=".cs" #>
<#
    int[] itemCounts = [10, 25, 50, 75, 100];
#>
// <auto-generated/>
#nullable enable

namespace SourceGen.Ioc.Benchmark.Benchmarks;

#region Generated Test Types

<#
for (int i = 0; i < 100; i++)
{
#>
public sealed class TestType<#= i #>;
<#
}
#>

#endregion

#region Generated Type Arrays

public static partial class GeneratedTestData
{
<#
foreach (var count in itemCounts)
{
#>
    public static (Type, object)[] TestTypes<#= count #> { get; } =
    [
<#
    for (int i = 0; i < count; i++)
    {
        var comma = i < count - 1 ? "," : "";
#>
        (typeof(TestType<#= i #>), <#= i #>)<#= comma #>
<#
    }
#>
    ];

<#
}
#>
}

#endregion

#region Generated Switch Lookups

public static partial class GeneratedSwitchLookup
{
    private static readonly Func<object> DefaultFactory = static () => new object();

<#
foreach (var count in itemCounts)
{
#>
    public static Func<object>? Lookup<#= count #>((Type, object) val) => val switch
    {
<#
    for (int i = 0; i < count; i++)
    {
#>
        var (type, key) when type == typeof(TestType<#= i #>) && Equals(key, <#= i #>) => DefaultFactory,
<#
    }
#>
        _ => null
    };

<#
}
#>
}

#endregion
